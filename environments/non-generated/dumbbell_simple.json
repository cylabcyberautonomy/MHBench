              "flavor": "m1.small",
              "ip_address": "192.168.200.20"
            }
          ]
        },
        {
          "name": "attacker_subnet",
          "cidr": "192.168.202.0/24",
          "external": true,
          "dns_servers": [
            "8.8.8.8",
            "8.8.4.4"
          ],
          "hosts": [
            {
              "name": "kali",
              "vm_type": "kali_running",
              "flavor": "m2.large",
              "ip_address": "192.168.202.100",
              "extra_interfaces": [
                {
                  "subnet": "server_subnet",
                  "ip_address": "192.168.200.100"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "subnet_connections": [
