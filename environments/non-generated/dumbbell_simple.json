          "cidr": "192.168.100.0/24",
          "dns_servers": [
            "8.8.8.8",
            "8.8.4.4"
          ],
          "hosts": [
            {
              "name": "client_0",
              "vm_type": "ubuntu_base_running",
              "flavor": "m1.small",
              "ip_address": "192.168.100.10"
            },
            {
              "name": "client_1",
              "vm_type": "ubuntu_base_running",
              "flavor": "m1.small",
              "ip_address": "192.168.100.11"
            },
            {
              "name": "client_2",
              "vm_type": "ubuntu_base_running",
              "flavor": "m1.small",
              "ip_address": "192.168.100.12"
            }
          ]
        },
        {
          "name": "server_subnet",
          "cidr": "192.168.200.0/24",
          "dns_servers": [
            "8.8.8.8",
            "8.8.4.4"
          ],
          "hosts": [
            {
              "name": "webserver_0",
              "vm_type": "webserver_running",
              "flavor": "m1.small",
              "ip_address": "192.168.200.10"
            },
            {
              "name": "database_0",
